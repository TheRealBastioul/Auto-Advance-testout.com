(function() {
    const delay = (ms) => new Promise(res => setTimeout(res, ms));
    let scoreDetected = false;

    // Primary Detection: Performance Observer (Catches cross-origin & background requests)
    const observer = new PerformanceObserver((list) => {
        for (const entry of list.getEntries()) {
            if (entry.name.includes('scores')) {
                console.log("%c [SIGNAL] Score detected via Performance API ", "color: #3498db; font-weight: bold;");
                scoreDetected = true;
            }
        }
    });
    observer.observe({ entryTypes: ['resource'] });

    // Secondary Detection: Manual Patching (Your original logic for same-origin frames)
    function applyInterceptor(win) {
        try {
            if (!win || win._patched) return;
            const orgFetch = win.fetch;
            win.fetch = async (...args) => {
                const url = args[0] instanceof Request ? args[0].url : args[0];
                if (typeof url === 'string' && url.includes('scores')) {
                    console.log("%c [DETECTION] Fetch caught in Frame! ", "color: #2ecc71; font-weight: bold;");
                    scoreDetected = true;
                }
                return orgFetch(...args);
            };
            const orgOpen = win.XMLHttpRequest.prototype.open;
            win.XMLHttpRequest.prototype.open = function(method, url) {
                if (typeof url === 'string' && url.includes('scores')) {
                    console.log("%c [DETECTION] XHR caught in Frame! ", "color: #2ecc71; font-weight: bold;");
                    scoreDetected = true;
                }
                return orgOpen.apply(this, arguments);
            };
            win._patched = true;
        } catch (e) {}
    }

    // Helper: Wait for module change without hardcoded timers
    async function waitForModuleLoad(oldId) {
        let elapsed = 0;
        while (elapsed < 10000) { // 10s safety max
            const activeLink = document.querySelector('.ResourceItem-link.active, .ResourceItem-link.selected');
            const newId = activeLink ? activeLink.innerText : "";
            if (newId !== oldId && newId !== "") return;
            await delay(500);
            elapsed += 500;
        }
    }

    async function autoAdvance() {
        while (true) {
            // Apply patches to all reachable contexts
            applyInterceptor(window);
            document.querySelectorAll('iframe').forEach(frm => applyInterceptor(frm.contentWindow));

            const activeLink = document.querySelector('.ResourceItem-link.active, .ResourceItem-link.selected');
            const currentModuleId = activeLink ? activeLink.innerText : "";
            const isText = activeLink && activeLink.querySelector('.fa-file-lines');

            if (isText) {
                scoreDetected = false;
                performance.clearResourceTimings(); 
                console.log(`Text module: Waiting for score for "${currentModuleId}"...`);
                window.scrollTo({ top: document.documentElement.scrollHeight, behavior: 'smooth' });

                let seconds = 0;
                while (!scoreDetected) {
                    await delay(1000);
                    seconds++;
                    if (seconds % 5 === 0) console.log(`Searching frames for signal... ${seconds}s`);
                    // Keep re-patching in case frames reload
                    document.querySelectorAll('iframe').forEach(frm => applyInterceptor(frm.contentWindow));
                }
                console.log("Success. Moving on.");
            } else {
                console.log("Skipping non-text module...");
                await delay(3000);
            }

            const nextBtn = document.querySelector('.ProductViewer-nav-button-next') || 
                            Array.from(document.querySelectorAll('.ProductViewer-nav-button')).find(b => b.innerText.includes('Next'));

            if (nextBtn) {
                scoreDetected = false;
                nextBtn.click();
                await waitForModuleLoad(currentModuleId);
            } else {
                console.log("Course complete.");
                break;
            }
        }
    }

    autoAdvance();
})();
